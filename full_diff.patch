+    }
+
+    #[cfg(feature = "rkyv")]
+    fn import_from_archived_sparse(
+        &mut self,
+        archived: &rkyv::Archived<crate::book::backend::sparse::SparseBackend>,
+    ) {
+        self.adapt_from_archived_sparse(archived);
+    }
